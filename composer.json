{
  "name": "natasya/nata-app",
  "description": "Aplikasi data dan monitoring peserta pelatihan tenaga kerja pada Dinas Koperasi, UM, dan Tenaga Kerja Kota Banjarbaru.",
  "type": "project",
  "license": "proprietary",
  "autoload": {
    "psr-4": {
      "Natasya\\NataApp\\": "app/",
      "Database\\": "database/"
    },
    "files": [
      "app/Helpers/helper.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "Natasya\\NataApp\\" : "test"
    }
  },
  "require": {
    "php" : ">=8",
    "ext-pdo": "*",
    "ext-mbstring": "*",
    "ext-curl": "*",
    "monolog/monolog": "^3.10",
    "nesbot/carbon": "^3.13",
    "ramsey/uuid": "^4.9",
    "vlucas/phpdotenv": "^5.6",
    "simplesoftwareio/simple-qrcode": "^4.2",
    "endroid/qr-code": "^5.0",
    "dragonmantank/cron-expression": "^3.6",
    "phpmailer/phpmailer": "^7.1",
    "illuminate/database": "12"
  },
  "require-dev": {
    "phpunit/phpunit": "^12",
    "fakerphp/faker": "^1.24"
  }
}
